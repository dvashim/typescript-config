{
  "name": "@dvashim/typescript-config",
  "version": "4.0.2",
  "description": "Shared TypeScript configurations",
  "keywords": [
    "config",
    "shared-config",
    "tsconfig",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dvashim/typescript-config.git"
  },
  "license": "MIT",
  "author": "Aleksei Reznichenko <aleksei@dvashim.dev>",
  "type": "module",
  "exports": {
    ".": "./dist/tsconfig.base.json",
    "./node": "./dist/tsconfig.node.json",
    "./lib-dev": "./dist/tsconfig.lib-dev.json",
    "./lib-prod": "./dist/tsconfig.lib-prod.json",
    "./app-react": "./dist/tsconfig.app-react.json",
    "./app-react-vite": "./dist/tsconfig.app-react-vite.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "changeset": "changeset",
    "check": "pnpm run \"/^check:.*/\"",
    "check:exports": "validate-package-exports --check",
    "check:format": "biome format .",
    "check:ts": "for f in ./tests/*.json; do tsc -p \"$f\" || exit 1; done"
  },
  "peerDependencies": {
    "typescript": ">=6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@dvashim/biome-config": "^1.7.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "validate-package-exports": "^0.24.0",
    "vite": "^8.0.10"
  },
  "packageManager": "pnpm@11.0.4",
  "publishConfig": {
    "access": "public"
  }
}
