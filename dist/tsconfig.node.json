{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modules
    "module": "esnext",
    "allowImportingTsExtensions": true,
    "types": ["node"],

    // Emit
    "noEmit": true,

    // Language and Environment
    "target": "es2023",
    "lib": ["ES2023"]
  }
}
