{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Module
    "module": "esnext",
    "allowImportingTsExtensions": true,

    // Target / Language
    "target": "es2023",
    "lib": ["ES2023"],

    // Types
    "types": ["node"],

    // Emit
    "noEmit": true
  }
}