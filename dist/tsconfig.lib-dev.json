{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modules
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,

    // Emit
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Interop Constraints
    "isolatedDeclarations": true,

    // Projects
    "composite": true
  }
}
