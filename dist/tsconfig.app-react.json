{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modules
    "allowImportingTsExtensions": true,

    // Emit
    "noEmit": true,

    // Language and Environment
    "jsx": "react-jsx",
    "lib": ["ES2025", "DOM", "DOM.Iterable", "DOM.AsyncIterable"]
  }
}
