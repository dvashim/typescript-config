{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modules
    "module": "esnext",
    "allowImportingTsExtensions": true,
    "types": [],

    // Emit
    "noEmit": true,

    // Language and Environment
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable", "DOM.AsyncIterable"]
  }
}
