{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Module
    "module": "esnext",
    "allowImportingTsExtensions": true,

    // JSX
    "jsx": "react-jsx",

    // Environment
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    // Emit
    "noEmit": true
  }
}