{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // Modules
    "module": "esnext",
    "allowImportingTsExtensions": true,

    // Emit
    "noEmit": true,

    // Language and Environment
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  }
}
